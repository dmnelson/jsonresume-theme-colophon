  "exports": "./dist/index.js",
  "types": "index.d.ts",
  "author": {
    "name": "David Nelson",
    "url": "https://github.com/dmnelson"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dmnelson/jsonresume-theme-colophon.git"
  },
  "homepage": "https://github.com/dmnelson/jsonresume-theme-colophon#readme",
